# --- OpenLibrary Authentication ---
# The email address used to log into OpenLibrary.org
OL_USERNAME=your_email@example.com

# The password for your OpenLibrary account
OL_PASSWORD=your_password_here

# --- Profile Settings ---
# Your internal OpenLibrary handle (found in your profile URL: /people/username)
# This is used to verify reading list counts.
OL_INER_USERNAME=your_username_handle

# --- Execution Settings ---
# Set to 'true' to run without a browser window, 'false' to see the automation in action.
HEADLESS=false